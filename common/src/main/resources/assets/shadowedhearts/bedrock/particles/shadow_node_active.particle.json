{
    "format_version": "1.10.0",
    "particle_effect": {
        "description": {
            "identifier": "shadowedhearts:shadow_node_active",
            "basic_render_parameters": {
                "material": "particles_blend",
                "texture": "textures/particle/generic/sparkle/glowingsparkle"
            }
        },
        "components": {
            "minecraft:emitter_rate_steady": {
                "spawn_rate": 0.05,
                "max_particles": 1
            },
            "minecraft:emitter_lifetime_looping": {
                "active_time": 100
            },
            "minecraft:emitter_shape_disc": {
                "offset": [0, 0.05, 0],
                "radius": 1.0,
                "surface_only": false,
                "direction": [0, 1, 0]
            },
            "minecraft:particle_lifetime_expression": {
                "max_lifetime": "5.5 + math.random(0, 1.5)"
            },
            "minecraft:particle_initial_speed": "0.05 + math.random(0, 0.07)",
            "minecraft:particle_motion_dynamic": {
                "linear_acceleration": [0, 0.08, 0]
            },
            "minecraft:particle_initial_spin": {
                "rotation": "math.random(0, 360)"
            },
            "minecraft:particle_appearance_billboard": {
                "size": [0.14, 0.14],
                "facing_camera_mode": "rotate_xyz",
                "uv": {
                    "texture_width": 8,
                    "texture_height": 8,
                    "flipbook": {
                        "base_UV": [
                            8,
                            0
                        ],
                        "size_UV": [
                            8,
                            8
                        ],
                        "step_UV": [
                            8,
                            0
                        ],
                        "frames_per_second": 8,
                        "max_frame": 4
                    }
                }
            },
            "minecraft:particle_appearance_tinting": {
                "color": {
                    "interpolant": "v.particle_age / v.particle_lifetime",
                    "gradient": {
                        "0.0": "#FFFFFFFF",
                        "0.3": "#CC88CCFF",
                        "0.7": "#884499EE",
                        "1.0": "#00224488"
                    }
                }
            }
        }
    }
}
